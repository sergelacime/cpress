{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cPress",
  "version": "0.1.0",
  "identifier": "com.cpress.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bash scripts/download-sidecars.sh && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "cPress — Compression de fichiers",
        "width": 1180,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "copyright": "Copyright © 2026 sergelacime",
    "publisher": "sergelacime",
    "shortDescription": "Compression locale de fichiers",
    "longDescription": "cPress est une application desktop open source pour compresser localement vos images, documents Office, PDF, fichiers audio et vidéo. Développée par sergelacime.",
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/ffmpeg"]
  }
}
